**/Corel\ Auto-Preserve/
# Ignore KiCad backup and autosave files
*.bak
#~*
#auto_saved_files#

# Ignore KiCad lock and cache files
*.kicad_sch-bak
*.kicad_pcb-bak
*.kicad_sch.lck
fp-info-cache
sym-lib-table.bak
fp-lib-table.bak

# Ignore project-specific temporary files
*.kicad_prl
*.kicad_dru
*.kicad_wks
*.kicad_pro.bak
*.kicad_plt
*-backups/
*-backups/**
\#*\#
*-lib-table

# Ignore spreadsheets and temp working files
*.ods
~$*.*

# -----------------------------------------------------------------------------
# Local credentials (never commit)
# -----------------------------------------------------------------------------
secrets.yaml
credentials-local.md
docs/credentials-local.md
*.env
.env*

# -----------------------------------------------------------------------------
# Home Assistant local/test files
# -----------------------------------------------------------------------------
secrets*.yaml
configuration.local.yaml

# -----------------------------------------------------------------------------
# Node-RED
# -----------------------------------------------------------------------------
*.backup.json
*.flows_cred.json

# -----------------------------------------------------------------------------
# SQL
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*.code-workspace
