    {
        "id": "build_ec_reference_select",
        "type": "function",
        "z": "3ec2ad8e53afdcdc",
        "name": "Build EC Reference SELECT",
        "func": "msg.topic = `\nSELECT\n    id,\n    captured_at,\n    meter_value,\n    meter_units,\n    probe_voltage,\n    tank_gallons,\n    water_temp_f,\n    rain_since_last_reference_in,\n    estimated_rain_added_gal,\n    note,\n    operator_note\nFROM hydro_tds_reference_reading\nORDER BY captured_at DESC\nLIMIT 20;\n`;\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 820,
        "y": 2280,
        "wires": [
            [
                "query_ec_reference_history"
            ]
        ]
    },
    {
        "id": "query_ec_reference_history",
        "type": "mysql",
        "z": "3ec2ad8e53afdcdc",
        "mydb": "mysql_logbook_placeholder",
        "name": "Query EC Reference History",
        "x": 1120,
