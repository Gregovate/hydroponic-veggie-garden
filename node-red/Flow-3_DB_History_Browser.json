    {
        "id": "format_ec_reference_history",
        "type": "function",
        "z": "3ec2ad8e53afdcdc",
        "name": "Format EC Reference History",
        "func": "const rows = Array.isArray(msg.payload) ? msg.payload : [];\n\n// Format numeric values for dashboard display.\n// Important: NULL database values must stay \"-\".\n// Without this check, JavaScript converts Number(null) to 0.\nfunction fmt(v, d) {\n    if (v === null || v === undefined || v === \"\") {\n        return \"-\";\n    }\n\n    const n = Number(v);\n\n    if (!Number.isFinite(n)) {\n        return \"-\";\n    }\n\n    return n.toFixed(d);\n}\n\nfunction fmtDate(v) {\n    const d = new Date(v);\n\n    if (Number.isNaN(d.getTime())) {\n        return String(v || \"\");\n    }\n\n    return d.toLocaleString(\"en-US\", {\n        weekday: \"short\",\n        month: \"short\",\n        day: \"numeric\",\n        hour: \"numeric\",\n        minute: \"2-digit\",\n        hour12: true\n    });\n}\n\nconst md = rows.map(r => {\n    let s = `### ${fmtDate(r.captured_at)}\\n`;\n\n    s += `**Meter:** ${fmt(r.meter_value, 2)} ${r.meter_units || \"\"}`;\n    s += `  •  **Probe:** ${fmt(r.probe_voltage, 3)} V`;\n    s += `  •  **Tank:** ${fmt(r.tank_gallons, 1)} gal`;\n    s += `  •  **Temp:** ${fmt(r.water_temp_f, 1)} °F\\n\\n`;\n\n    s += `Rain Since: ${fmt(r.rain_since_last_reference_in, 3)} in`;\n    s += `  •  Rain Added: ${fmt(r.estimated_rain_added_gal, 3)} gal\\n\\n`;\n\n    if (r.note) {\n        s += `${String(r.note)}\\n`;\n    }\n\n    if (r.operator_note) {\n        s += `\\n**Operator Note:** ${String(r.operator_note)}\\n`;\n    }\n\n    return s;\n}).join(\"\\n---\\n\");\n\nmsg.payload = JSON.stringify({\n    state: \"ok\",\n    ec_reference_text: md,\n    updated_at: new Date().toISOString()\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
