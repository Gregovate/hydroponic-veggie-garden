    {
        "id": "94fcd52572e0a087",
        "type": "function",
        "z": "3ec2ad8e53afdcdc",
        "name": "Build Recent Activity SELECT",
        "func": "const offset = Math.max(0, Number(msg.history_offset) || 0);\nconst limitRaw = Number(msg.history_limit) || 5;\nconst limit = Math.min(50, Math.max(1, limitRaw));\n\nmsg.topic = `\nSELECT *\nFROM v_hydro_recent_activity\nORDER BY activity_time DESC\nLIMIT ${limit}\nOFFSET ${offset};\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 1720,
        "wires": [
            [
                "f5ee07229a11f2f3"
            ]
        ]
    },
    {
        "id": "f5ee07229a11f2f3",
        "type": "mysql",
        "z": "3ec2ad8e53afdcdc",
        "mydb": "mysql_logbook_placeholder",
        "name": "Query Recent Activity",
        "x": 1100,
