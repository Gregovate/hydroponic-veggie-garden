[
    {
        "id": "hydro_history_build_save_note_sql",
        "type": "function",
        "z": "3ec2ad8e53afdcdc",
        "name": "Add Note to Selected Event",
        "func": "// Save operator note to selected Hydro-History activity record.\n\nconst selectedActivity = String(\n    msg.payload?.maintenance_log_id ??\n    msg.payload?.event?.maintenance_log_id ??\n    msg.event?.maintenance_log_id ??\n    \"\"\n).trim();\n\nconst operatorNote = String(\n    msg.payload?.operator_note ??\n    msg.payload?.event?.operator_note ??\n    msg.event?.operator_note ??\n    \"\"\n).trim();\n\nfunction sqlText(value) {\n    if (value === undefined || value === null) return \"NULL\";\n    const s = String(value).trim();\n    if (s.length === 0) return \"NULL\";\n    return \"'\" + s.replace(/'/g, \"''\").slice(0, 255) + \"'\";\n}\n\nif (!selectedActivity.includes(\":\")) {\n    node.error(\"Save operator note failed: selected activity must include source:id\", msg);\n    return null;\n}\n\nconst [activitySource, idText] = selectedActivity.split(\":\");\nconst sourceId = Number(idText);\n\nif (!Number.isInteger(sourceId) || sourceId <= 0) {\n    node.error(\"Save operator note failed: invalid selected activity id\", msg);\n    return null;\n}\n\nif (!operatorNote) {\n    node.error(\"Save operator note failed: operator note is empty\", msg);\n    return null;\n}\n\nif (activitySource === \"maintenance_log\") {\n    msg.topic = `\nUPDATE maintenance_log\nSET operator_note = ${sqlText(operatorNote)}\nWHERE id = ${sourceId};\n`;\n} else if (activitySource === \"ec_reference\") {\n    msg.topic = `\nUPDATE hydro_tds_reference_reading\nSET operator_note = ${sqlText(operatorNote)}\nWHERE id = ${sourceId};\n`;\n} else {\n    node.error(`Save operator note failed: unsupported activity source ${activitySource}`, msg);\n    return null;\n}\n\nmsg.payload = {\n    activity_source: activitySource,\n    source_id: sourceId,\n    operator_note: operatorNote\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
